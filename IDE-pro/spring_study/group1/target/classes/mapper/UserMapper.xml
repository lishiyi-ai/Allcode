<!--            parameterType="Integer"-->
<!--            resultType="lishiyi.pojo.User">-->
<!--        select <include refid="userColumns">-->
<!--            <property name="alias" value="t1"/>-->
<!--        </include>-->
<!--            from users where uid=#{id}-->
<!--    </select>-->
<!--    使用主键自动增长-->
    <insert id="addUser" parameterType="User" useGeneratedKeys="true">
        insert into users(uid,uname,uage) values(#{uid},#{uname},#{uage})
    </insert>
<!--
    <insert id="addUser" parameterType="User" useGeneratedKeys="true">
    <selectKey keyProperty="uid" resultType="Integer" oreder="BEFORE">
        select if(max(uid) is null,1,max(uid)+1) as newId from users
    </selectKey>
        insert into users(uid,uname,uage) values(#{uid},#{uname},#{uage})
    </insert>
-->
    <update id="updateUser" parameterType="User">
        update users set uname=#{uname},uage=#{uage} where uid=#{uid}
    </update>

    <delete id="deleteUser" parameterType="Integer">
        delete from users where uid=#{uid}
    </delete>
</mapper>